    given-names: "Elzon Cassio"
    orcid: "https://orcid.org/0000-0002-8391-4435"
    affiliation: "Universidade Federal de Santa Maria (UFSM)"
version: "1.0.0"
date-released: "2026-04-26"
license: MIT
